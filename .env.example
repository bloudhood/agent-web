# Web 登录密码（可选，不设则首次启动自动生成随机密码）
# CC_WEB_PASSWORD=your-password-here

# 服务监听端口（默认 8002）
PORT=8002

# Claude CLI 路径（默认在 PATH 中查找 claude）
CLAUDE_PATH=claude

# Codex CLI 路径（默认在 PATH 中查找 codex）
CODEX_PATH=codex

# Gemini CLI 路径（默认在 PATH 中查找 gemini）
GEMINI_PATH=gemini

# Hermes Gateway（WSL/本机均可；默认监听 127.0.0.1:8644）
CC_WEB_HERMES_API_BASE=http://127.0.0.1:8644
# CC_WEB_HERMES_API_KEY=

# 运行态目录覆写（主要供隔离测试、容器、便携部署使用）
# CC_WEB_CONFIG_DIR=./config
# CC_WEB_SESSIONS_DIR=./sessions
# CC_WEB_LOGS_DIR=./logs

# PushPlus Token（可选，首次启动会自动迁移到 config/notify.json）
PUSHPLUS_TOKEN=
